ALERTMESH_DATABASE_DSN=postgres://alertmesh:secret@localhost:5432/alertmesh?sslmode=disable

# Master encryption key – AES-256, base64 of exactly 32 bytes.
# Generate: openssl rand -base64 32
# This is the ONLY secret that must stay in the environment.
# All other secrets (JWT signing key, LDAP/OIDC credentials) are generated
# automatically and stored AES-256-GCM encrypted in system_configs.
ALERTMESH_ENCRYPTION_KEY=base64-encoded-32-byte-aes-key==

ALERTMESH_LOG_LEVEL=info
ALERTMESH_AI_WORKERS=2

# AI root cause analysis data sources (Prometheus + OpenSearch = full RCA)
# ALERTMESH_PROMETHEUS_URL=http://prometheus:9090
# ALERTMESH_OPENSEARCH_URL=http://opensearch:9200

# Optional extensions (disabled by default)
# ALERTMESH_REDIS_ENABLED=true
# ALERTMESH_REDIS_ADDR=localhost:6379
# ALERTMESH_K8S_ENABLED=true
# ALERTMESH_K8S_CLUSTER_NAME=prod-k8s-01
